# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only (NO prefijar con NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=xxx

# Login del admin (/admin): email + contraseña
ADMIN_EMAIL=tu-email@ejemplo.com
ADMIN_PASSWORD=una-contraseña-fuerte
# Secreto para firmar la cookie de sesión (ej: openssl rand -hex 32)
ADMIN_SESSION_SECRET=xxx

# Emails transaccionales (opcional Fase 1)
RESEND_API_KEY=
